{
  "_comment": "视频处理流程配置文件 — 复制为 config.json 并填入真实值",
  "_processing_order": "001移除黑屏 -> 002分离声道 -> 004转场拼接 -> 003字幕生成与烧录 -> 选曲+剪映草稿",

  "kimi_api_key": "sk-your-kimi-api-key-here",
  "deepseek_api_key": null,

  "msst_conda_env": "msst",

  "paths": {
    "assets": "assets",
    "temp_output": "temp_output",
    "output": "output",
    "libs": "libs",
    "scripts": {
      "remove_black": "scripts/001remove_black.py",
      "separate": "scripts/002separate.py",
      "subtitles": "scripts/003subtitles_simple.py",
      "transition": "scripts/004transition_v2.py"
    }
  },

  "remove_black": {
    "brightness_threshold": 50,
    "fade_threshold": 110,
    "min_duration": 0.1,
    "check_text": true,
    "use_ai": false
  },

  "separate": {
    "output_format": "wav"
  },

  "subtitles": {
    "script_dir": null
  },

  "transition": {
    "use_random_transitions": true,
    "bgm_volume": 0.3
  },

  "draft_package": {
    "_comment": "百度网盘同步路径，用于将剪映草稿自动同步到 Mac 可访问的目录",
    "windows_sync_path": "C:\\Users\\your-username\\Documents\\BaiduSyncdisk",
    "mac_sync_path": "/Users/your-mac-username/Downloads/同步空间",
    "draft_subfolder": "JianyingPro Drafts"
  }
}
